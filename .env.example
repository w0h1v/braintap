# BrainTap environment configuration
#
# The app runs fully offline using localStorage when these are not set.
# Set them to enable accounts (Google + email/password), cloud sync, and
# global leaderboards via Supabase.

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable (anon) key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site URL used for OAuth redirects (defaults to the request origin)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
