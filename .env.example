# BrainTap environment configuration
#
# The app runs fully offline using localStorage when these are not set.
# Set them to enable accounts (Google + email/password), cloud sync, and
# global leaderboards via Supabase.

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable (anon) key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site URL used for OAuth redirects (defaults to the request origin)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Native iOS build only (Capacitor) -------------------------------------
# Google OAuth client ids for native Sign-in (from Google Cloud Console).
# iOS client id → also paste its reversed form into ios/App/App/Info.plist
# (CFBundleURLTypes). webClientId is the audience Supabase's Google provider trusts.
NEXT_PUBLIC_GOOGLE_IOS_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Real AdMob ad-unit ids (fall back to Google TEST units when unset). Set both,
# flip ads/index.ts initializeForTesting→false, and set the real
# GADApplicationIdentifier in Info.plist before submitting.
NEXT_PUBLIC_ADMOB_REWARDED_ID=
NEXT_PUBLIC_ADMOB_INTERSTITIAL_ID=

# RevenueCat public SDK keys (from the RevenueCat dashboard, per platform).
NEXT_PUBLIC_REVENUECAT_IOS_KEY=
NEXT_PUBLIC_REVENUECAT_ANDROID_KEY=
